// Gestion de la navigation vers l'\'e9tape suivante plus verification\par
document.addEventListener("DOMContentLoaded", function () \{\par
    const steps = document.querySelectorAll(".step");\par
    const stepIndicators = document.querySelectorAll(".step-number");\par
    const nextButtons = document.querySelectorAll(".next");\par
    const prevButtons = document.querySelectorAll(".prev");\par
\par
    let currentStep = 0;\par
\par
    // Fonction pour passer \'e0 l'\'e9tape suivante et mettre \'e0 jour la ligne\par
    function showStep(stepIndex) \{\par
        steps.forEach((step, index) => \{\par
            step.classList.toggle("active", index === stepIndex);\par
        \});\par
        \par
        // Mettre \'e0 jour les indicateurs d'\'e9tape\par
        stepIndicators.forEach((indicator, index) => \{\par
            indicator.classList.toggle("active", index <= stepIndex);\par
            if (index < stepIndex) \{\par
                indicator.closest(".step-indicator").classList.add("completed");\par
            \} else \{\par
                indicator.closest(".step-indicator").classList.remove("completed");\par
            \}\par
        \});\par
\par
        currentStep = stepIndex;\par
    \}\par
\par
    // Validation avant de passer \'e0 l'\'e9tape suivante\par
    nextButtons.forEach((button, index) => \{\par
        button.addEventListener("click", function () \{\par
            // Trouver tous les champs du formulaire de l'\'e9tape actuelle\par
            const fields = steps[currentStep].querySelectorAll("input, select");\par
\par
            let allValid = true;\par
\par
            fields.forEach(field => \{\par
                // V\'e9rifier la validit\'e9 des champs\par
                if (!field.checkValidity()) \{\par
                    allValid = false;\par
                    field.reportValidity(); // Afficher un message d'erreur\par
                \}\par
            \});\par
\par
            // V\'e9rifier les e-mails\par
            if (currentStep === 4) \{ // Supposons que l'\'e9tape 1 est celle des e-mails\par
                let email = document.getElementById('email').value;\par
                let confirmEmail = document.getElementById('confirmEmail').value;\par
\par
                // V\'e9rifier le format des e-mails\par
                const emailPattern = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\par
                if (!emailPattern.test(email) || !emailPattern.test(confirmEmail)) \{\par
                    alert("Veuillez entrer une adresse e-mail valide.");\par
                    allValid = false;\par
                \}\par
\par
                // V\'e9rifier si les e-mails correspondent\par
                if (email !== confirmEmail) \{\par
                    alert("Les adresses e-mail ne correspondent pas.");\par
                    allValid = false;\par
                \}\par
            \}\par
\par
            // Si tous les champs sont valides, on peut passer \'e0 l'\'e9tape suivante\par
            if (allValid) \{\par
                showStep(currentStep + 1);\par
            \}\par
        \});\par
    \});\par
\par
    // Revenir \'e0 l'\'e9tape pr\'e9c\'e9dente\par
    prevButtons.forEach((button, index) => \{\par
        button.addEventListener("click", function () \{\par
            showStep(currentStep - 1);\par
        \});\par
    \});\par
\par
    // Initialiser en affichant la premi\'e8re \'e9tape\par
    showStep(0);\par
\});\par
\par
</script>\par
