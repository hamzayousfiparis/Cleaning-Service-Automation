document.addEventListener("DOMContentLoaded", async function() \{\par
    await fetchReservations();\par
\par
    const hourSelect = document.getElementById("nombreheurs");\par
    const dateInput = document.getElementById("date1");\par
    const timeInput = document.getElementById("heureDebut1");\par
    const timeList = document.getElementById("timeList");\par
    const notificationMessage = document.getElementById("notificationMessage");\par
\par
    // D\'e9sactiver les champs date et heure tant que le nombre d'heures n'est pas s\'e9lectionn\'e9\par
    dateInput.disabled = true;\par
    timeInput.disabled = true;\par
\par
    hourSelect.addEventListener("change", function() \{\par
        const selectedHours = this.value;\par
\par
        if (selectedHours) \{\par
            dateInput.disabled = false;  // Activer le champ de date\par
            notificationMessage.textContent = ""; // Effacer le message de notification\par
        \} else \{\par
            dateInput.disabled = true;\par
            timeInput.disabled = true;\par
            notificationMessage.textContent = ""; // Effacer le message de notification\par
        \}\par
\par
        // R\'e9initialiser les champs date et heure lorsque le nombre d'heures change\par
        dateInput.value = "";\par
        timeInput.value = "";\par
        timeInput.disabled = true;\par
        timeList.innerHTML = ''; // Vider la liste des heures disponibles\par
    \});\par
\par
    dateInput.addEventListener("change", function() \{\par
    const selectedDate = this.value;\par
    const selectedHours = parseInt(hourSelect.value);\par
\par
    // R\'e9initialiser les cr\'e9neaux horaires\par
    timeInput.value = "";\par
    timeList.innerHTML = '';  // Vider la liste des heures disponibles\par
    timeInput.disabled = true;\par
\par
    if (!selectedHours) \{\par
        notificationMessage.textContent = "Veuillez s\'e9lectionner le nombre d'heures avant de choisir la date et l'heure.";\par
        return;\par
    \}\par
\par
    const now = new Date();\par
    const minDateTime = new Date(now.getTime() + 3 * 60 * 60 * 1000); // Ajoute 3 heures \'e0 l'heure actuelle\par
\par
    let availableTimes = generateAvailableTimes(minDateTime, selectedDate);\par
\par
    // V\'e9rifie les heures r\'e9serv\'e9es et les exclut des heures disponibles\par
    reservedTimes.forEach(reservation => \{\par
        const reservedDate = reservation[0];\par
        const reservedTime = reservation[1];\par
        let reservedDuration = parseInt(reservation[2]) || 1; // Dur\'e9e de r\'e9servation avec 1h par d\'e9faut\par
\par
        if (selectedDate === reservedDate) \{\par
            const reservedStartTime = new Date(`$\{reservedDate\}T$\{reservedTime\}`);\par
            const reservedEndTime = new Date(reservedStartTime.getTime() + (reservedDuration + 2) * 60 * 60 * 1000);\par
\par
            availableTimes = filterAvailableTimes(availableTimes, selectedDate, reservedStartTime, reservedEndTime, selectedHours);\par
        \}\par
    \});\par
\par
    if (availableTimes.length === 0) \{\par
        notificationMessage.textContent = "Aucune heure disponible pour cette date. Veuillez choisir une autre date.";\par
        this.value = '';  // R\'e9initialise la date s\'e9lectionn\'e9e\par
        timeInput.disabled = true;\par
    \} else \{\par
        availableTimes.forEach(time => \{\par
            const timeOption = document.createElement("option");\par
            timeOption.value = time;\par
            timeList.appendChild(timeOption);\par
        \});\par
        timeInput.disabled = false;\par
        notificationMessage.textContent = ""; // Effacer le message de notification\par
    \}\par
\});\par
\par
\par
    timeInput.addEventListener("focus", function() \{\par
        if (hourSelect.value === "") \{\par
            notificationMessage.textContent = "Veuillez s\'e9lectionner le nombre d'heures avant de choisir l'heure.";\par
            this.blur(); // Enl\'e8ve le focus du champ d'heure\par
        \}\par
    \});\par
\par
    dateInput.addEventListener("focus", function() \{\par
        if (hourSelect.value === "") \{\par
            notificationMessage.textContent = "Veuillez s\'e9lectionner le nombre d'heures avant de choisir la date.";\par
            this.blur(); // Enl\'e8ve le focus du champ de date\par
        \}\par
    \});\par
\});\par
\par
async function fetchReservations() \{\par
    let reservedTimes = [];\par
\par
    for (const sheet of SPREADSHEET_IDS) \{\par
        const response = await fetch(`https://sheets.googleapis.com/v4/spreadsheets/$\{sheet.id\}/values/$\{sheet.range\}?key=$\{API_KEY\}`);\par
        const data = await response.json();\par
\par
        if (data.values) \{\par
            reservedTimes = reservedTimes.concat(data.values);\par
        \}\par
    \}\par
\par
    console.log(reservedTimes); // V\'e9rifiez les donn\'e9es ici\par
\par
    if (reservedTimes.length === 0) \{\par
        document.getElementById("availabilityMessage").innerText = "Aucune r\'e9servation trouv\'e9e.";\par
        return;\par
    \}\par
\par
    const dateInput = document.getElementById("date1");\par
    const today = new Date().toISOString().split('T')[0];\par
    dateInput.setAttribute("min", today);\par
\par
    // Ajouter des champs suppl\'e9mentaires si n\'e9cessaires\par
    reservedTimes = reservedTimes.map(reservation => \{\par
        if (reservation.length < 3) \{\par
            reservation.push(1); // Par d\'e9faut, dur\'e9e d'1 heure si non sp\'e9cifi\'e9e\par
        \}\par
        return reservation;\par
    \});\par
\par
    window.reservedTimes = reservedTimes; // Stocker les r\'e9servations dans une variable globale pour \'eatre utilis\'e9e plus tard\par
\}\par
\par
function generateAvailableTimes(minDateTime, selectedDate) \{\par
    const availableTimes = [];\par
    const now = new Date();\par
    const [minHours, minMinutes] = [minDateTime.getHours(), minDateTime.getMinutes()];\par
\par
    for (let hour = 7; hour < 21; hour++) \{\par
        for (let minute = 0; minute <= 30; minute += 30) \{\par
            const timeSlot = new Date(`$\{selectedDate\}T$\{String(hour).padStart(2, '0')\}:$\{String(minute).padStart(2, '0')\}`);\par
            if (new Date(selectedDate).toDateString() === now.toDateString()) \{\par
                if (timeSlot < minDateTime || timeSlot < now) \{\par
                    continue; // Ignorer les heures pass\'e9es ou dans les 3 prochaines heures\par
                \}\par
            \} else if (timeSlot < minDateTime) \{\par
                continue; // Ignorer les cr\'e9neaux avant minDateTime si la date est diff\'e9rente\par
            \}\par
            availableTimes.push(`$\{String(hour).padStart(2, '0')\}:$\{String(minute).padStart(2, '0')\}`);\par
        \}\par
    \}\par
    return availableTimes;\par
\}\par
\par
function filterAvailableTimes(availableTimes, selectedDate, reservedStartTime, reservedEndTime, selectedHours) \{\par
    const filteredTimes = availableTimes.filter(time => \{\par
        const timeSlot = new Date(`$\{selectedDate\}T$\{time\}`);\par
        const potentialEndTime = new Date(timeSlot.getTime() + (selectedHours + 2) * 60 * 60 * 1000);\par
\par
        // Filtrer les cr\'e9neaux en tenant compte des r\'e9servations avant et apr\'e8s\par
        return !(timeSlot >= reservedStartTime && timeSlot <= reservedEndTime) &&\par
               !(potentialEndTime >= reservedStartTime && potentialEndTime <= reservedEndTime) &&\par
               !(timeSlot <= reservedStartTime && potentialEndTime >= reservedEndTime);\par
    \});\par
\par
    return filteredTimes;\par
\}\par
