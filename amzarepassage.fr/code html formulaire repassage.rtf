// Fonction pour initialiser l'autocompl\'e9tion d'adresse avec Google Places API\par
\par
function initialize() \{\par
            var input = document.getElementById('address-autocomplete');\par
            var options = \{\par
                types: ['address'],\par
                componentRestrictions: \{ country: 'fr' \}\par
            \};\par
            var autocomplete = new google.maps.places.Autocomplete(input, options);\par
\par
            autocomplete.addListener('place_changed', function() \{\par
                var place = autocomplete.getPlace();\par
                var postalCode = '';\par
                var isIleDeFrance = false;\par
                var allowedPostalCodes = ['75', '77', '78', '91', '92', '93', '94', '95'];\par
                var address = '';\par
\par
                for (var i = 0; i < place.address_components.length; i++) \{\par
                    var addressType = place.address_components[i].types[0];\par
                    if (addressType === 'postal_code') \{\par
                        postalCode = place.address_components[i].long_name;\par
                        var postalCodePrefix = postalCode.substring(0, 2);\par
                        if (allowedPostalCodes.includes(postalCodePrefix)) \{\par
                            isIleDeFrance = true;\par
                        \}\par
                    \}\par
\par
                    // Build the full address string\par
                    address += place.address_components[i].long_name + ' ';\par
                \}\par
\par
                if (!isIleDeFrance) \{\par
                    alert("Veuillez s\'e9lectionner une adresse en \'cele-de-France.");\par
                    input.value = '';\par
                \} else \{\par
                    input.value = address.trim();\par
                \}\par
            \});\par
        \}\par
\par
        google.maps.event.addDomListener(window, 'load', initialize);\par
\par
// Format de num\'e9ro de t\'e9l\'e9phone \par
function formatPhoneNumber(input) \{\par
    // Retire tous les caract\'e8res qui ne sont pas des chiffres\par
    let value = input.value.replace(/\\D/g, '');\par
    \par
    // Ajoute des espaces entre chaque groupe de deux chiffres\par
    if (value.length > 0) \{\par
        value = value.replace(/(\\d\{2\})(?=\\d)/g, '$1 ');\par
    \}\par
\par
    // Limite la longueur \'e0 14 caract\'e8res (format 0X XX XX XX XX)\par
    input.value = value.trim().slice(0, 14);\par
\}\par
