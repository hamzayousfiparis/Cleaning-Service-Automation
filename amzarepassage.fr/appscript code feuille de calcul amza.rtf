\pard\sa200\sl276\slmult1\f0\fs22\lang12 // Script doPost pour g\'e9rer la soumission du formulaire\par
function doPost(e) \{\par
    try \{\par
        // V\'e9rifie si e est d\'e9fini et qu'il contient la propri\'e9t\'e9 'parameter'\par
        if (e && e.parameter) \{\par
            // Acc\'e8s aux donn\'e9es envoy\'e9es depuis le formulaire\par
            var nomComplet = e.parameter.fullName;\par
            var adresse = e.parameter.address;\par
            var numeroTelephone = e.parameter.phoneNumber;\par
            var email = e.parameter.email;\par
            var confirmEmail = e.parameter.confirmEmail;\par
            var date1 = e.parameter.date1;\par
            var heureDebut1 = e.parameter.heureDebut1;\par
            var nombreHeures = e.parameter.nombreheurs;\par
            var conditionsGenerales = e.parameter.conditionsGenerales;\par
\par
            var servicesouhaite = e.parameter.servicesouhaite;\par
            var frequence = e.parameter.frequence;\par
            var demandes = e.parameter.demandes;\par
\par
            // Enregistrement des donn\'e9es dans la feuille de calcul\par
            const sheet = SpreadsheetApp.openByUrl("https://docs.google.com/spreadsheets/d/1gUuYrWsG-S4NDaeRyTRsnQuDCYOqIAMkKrG6ee6tEUQ/edit?gid=0#gid=0").getSheetByName("data particulier");\par
            var lastRow = sheet.getLastRow();\par
            sheet.getRange(lastRow + 1, 1).setValue(nomComplet);\par
            sheet.getRange(lastRow + 1, 2).setValue(adresse);\par
            sheet.getRange(lastRow + 1, 3).setValue(numeroTelephone);\par
            sheet.getRange(lastRow + 1, 4).setValue(email);\par
            sheet.getRange(lastRow + 1, 5).setValue(confirmEmail);\par
            sheet.getRange(lastRow + 1, 6).setValue(date1);\par
            sheet.getRange(lastRow + 1, 7).setValue(heureDebut1);\par
            sheet.getRange(lastRow + 1, 8).setValue(nombreHeures);\par
            sheet.getRange(lastRow + 1, 9).setValue(conditionsGenerales);\par
            sheet.getRange(lastRow + 1, 10).setValue(servicesouhaite);\par
            sheet.getRange(lastRow + 1, 11).setValue(frequence);\par
            sheet.getRange(lastRow + 1, 12).setValue(demandes);\par
\par
            // Appel de la fonction pour g\'e9n\'e9rer le devis\par
            generateContract(nomComplet, adresse, numeroTelephone, email, date1, heureDebut1, nombreHeures);\par
\par
            // Appel de la fonction pour envoyer un SMS apr\'e8s la g\'e9n\'e9ration du contrat\par
            sendSMSNotification(nomComplet);\par
\par
            // Ajouter un \'e9v\'e9nement au calendrier Google\par
            ajouterEvenementAuCalendrier(nomComplet, adresse, numeroTelephone, email, date1, heureDebut1, nombreHeures);\par
\par
\par
            // R\'e9ponse de succ\'e8s \'e0 renvoyer au client\par
            return ContentService.createTextOutput("Donn\'e9es enregistr\'e9es avec succ\'e8s.");\par
        \} else \{\par
            throw new Error('Les donn\'e9es de la requ\'eate sont manquantes ou incorrectes.');\par
        \}\par
    \} catch (error) \{\par
        console.error(error);\par
        return ContentService.createTextOutput("Une erreur est survenue lors du traitement des donn\'e9es : " + error.message);\par
    \}\par
\}\par
