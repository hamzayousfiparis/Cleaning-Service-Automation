// Fonction onEdit pour envoyer un SMS lorsque les 9 premi\'e8res colonnes sont remplies\par
function onEdit(e) \{\par
    var sheet = e.source.getActiveSheet();\par
    \par
    // Remplacez par le nom de votre feuille\par
    if (sheet.getName() === "data particulier") \{\par
        var lastRow = sheet.getLastRow();\par
        \par
        // Utilisation de la colonne 13 pour v\'e9rifier si un SMS a \'e9t\'e9 envoy\'e9\par
        var smsSent = sheet.getRange(lastRow, 13).getValue(); // Colonne 13 r\'e9serv\'e9e \'e0 l'\'e9tat "Envoy\'e9"\par
        \par
        if (smsSent === "Envoy\'e9") \{\par
            // Si le SMS a d\'e9j\'e0 \'e9t\'e9 envoy\'e9, ne rien faire\par
            return;\par
        \}\par
\par
        // V\'e9rifie si toutes les colonnes n\'e9cessaires de la derni\'e8re ligne sont remplies\par
        var nomComplet = sheet.getRange(lastRow, 1).getValue();\par
        var adresse = sheet.getRange(lastRow, 2).getValue();\par
        var numeroTelephone = sheet.getRange(lastRow, 3).getValue();\par
        var email = sheet.getRange(lastRow, 4).getValue();\par
        var confirmEmail = sheet.getRange(lastRow, 5).getValue();\par
        var date1 = sheet.getRange(lastRow, 6).getValue();\par
        var heureDebut1 = sheet.getRange(lastRow, 7).getValue();\par
        var nombreHeures = sheet.getRange(lastRow, 8).getValue();\par
        var conditionsGenerales = sheet.getRange(lastRow, 9).getValue();\par
\par
        // V\'e9rifie si toutes les valeurs n\'e9cessaires sont pr\'e9sentes\par
        if (nomComplet && adresse && numeroTelephone && email && confirmEmail && date1 && heureDebut1 && nombreHeures && conditionsGenerales) \{\par
            // Envoi de la notification SMS\par
            sendSMSNotification(nomComplet);\par
            \par
            // Marque la ligne comme "Envoy\'e9" dans la colonne 13\par
            sheet.getRange(lastRow, 13).setValue("Envoy\'e9");\par
        \}\par
    \}\par
\}\par
\par
