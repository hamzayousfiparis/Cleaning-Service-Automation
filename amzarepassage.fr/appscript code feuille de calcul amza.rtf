// Fonction pour formater la date en DD-MM-YYYY\par
function formatDate(dateString) \{\par
    var date = new Date(dateString);\par
    var day = ('0' + date.getDate()).slice(-2);\par
    var month = ('0' + (date.getMonth() + 1)).slice(-2);\par
    var year = date.getFullYear();\par
    return day + '-' + month + '-' + year;\par
\}\par
\par
// Fonction pour formater l'heure en HHhMM\par
function formatTime(timeString) \{\par
    var [hours, minutes] = timeString.split(':');\par
    return hours + 'h' + minutes;\par
\}\par
\par
// Fonction pour g\'e9n\'e9rer le contrat\par
function generateContract(nomComplet, adresse, numeroTelephone, email, date1, heureDebut1, nombreHeures) \{\par
    const TEMPLATE_ID = '1fsdc3tPacmw2-VTEuJY8dM3GhTu7OlGdnBjnudzXjT8'; // Remplacez par l'ID de votre mod\'e8le Google Docs\par
    const folderId = '1C7CS-zHRlK5-E5tSieH7IpeaG4ZmgQom'; // Remplacez par l'ID de votre dossier o\'f9 vous souhaitez enregistrer le contrat\par
    const folder = DriveApp.getFolderById(folderId); // Acc\'e8s au dossier\par
\par
    // Formater la date et l'heure\par
    var formattedDate = formatDate(date1);\par
    var formattedTime = formatTime(heureDebut1);\par
\par
    // Copie du mod\'e8le de devis\par
    try \{\par
        const templateFile = DriveApp.getFileById(TEMPLATE_ID);\par
        // Inclure la date dans le nom du fichier\par
        const newFile = templateFile.makeCopy(`Devis de $\{nomComplet\} - $\{formattedDate\}`, folder);\par
        const newDoc = DocumentApp.openById(newFile.getId());\par
        const body = newDoc.getBody();\par
\par
        // Remplacement des placeholders\par
        body.replaceText('\{\{fullName\}\}', nomComplet);\par
        body.replaceText('\{\{address\}\}', adresse);\par
        body.replaceText('\{\{phoneNumber\}\}', numeroTelephone);\par
        body.replaceText('\{\{email\}\}', email);\par
        body.replaceText('\{\{date1\}\}', formattedDate);\par
        body.replaceText('\{\{heureDebut1\}\}', formattedTime);\par
        body.replaceText('\{\{nombreheurs\}\}', nombreHeures);\par
\par
        // Enregistrement des modifications\par
        newDoc.saveAndClose();\par
        \par
        Logger.log(`Le contrat a \'e9t\'e9 cr\'e9\'e9 : $\{newDoc.getUrl()\}`);\par
    \} catch (error) \{\par
        Logger.log(`Erreur lors de la cr\'e9ation du contrat : $\{error.message\}`);\par
    \}\par
\}\par
\par
\par
