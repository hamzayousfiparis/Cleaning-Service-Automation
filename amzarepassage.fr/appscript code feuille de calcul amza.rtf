// La fonction d'envoi de SMS\par
function sendSMSNotification(nomComplet) \{\par
    const FIXED_RECIPIENT_NUMBER = '+33644932146'; // Remplacez par le num\'e9ro de t\'e9l\'e9phone du destinataire\par
    let messageBody = `Nouveau client: $\{nomComplet\}`;\par
\par
    const payload = \{\par
        phone: FIXED_RECIPIENT_NUMBER,\par
        message: messageBody,\par
        key: '98c5bf096b72d0002f00b91c48c1ca4363eb12b3CbW9m7taEWx8n6EWIUCB6MMgN' // Remplacez par votre jeton API Textbelt\par
    \};\par
\par
    const options = \{\par
        method: 'post',\par
        contentType: 'application/json',\par
        payload: JSON.stringify(payload),\par
        muteHttpExceptions: true\par
    \};\par
\par
    const url = '{{\field{\*\fldinst{HYPERLINK https://textbelt.com/text }}{\fldrslt{https://textbelt.com/text\ul0\cf0}}}}\f0\fs22 ';\par
    try \{\par
        const response = UrlFetchApp.fetch(url, options);\par
        const responseJson = JSON.parse(response.getContentText());\par
        \par
        Logger.log('R\'e9ponse de l\\'API Textbelt: ' + JSON.stringify(responseJson));\par
\par
        if (responseJson.success) \{\par
            Logger.log('SMS envoy\'e9 avec succ\'e8s. ID du message : ' + responseJson.textId);\par
        \} else \{\par
            Logger.log('Erreur lors de l\\'envoi du SMS: ' + responseJson.error);\par
        \}\par
    \} catch (error) \{\par
        Logger.log('Erreur lors de l\\'appel \'e0 l\\'API Textbelt: ' + error);\par
    \}\par
\}\par
\par
\par
function ajouterEvenementAuCalendrier(nomComplet, adresse, numeroTelephone, email, date1, heureDebut1, nombreHeures) \{\par
    var calendar = CalendarApp.getDefaultCalendar(); // Utilise le calendrier par d\'e9faut\par
    var startTime = new Date(date1 + ' ' + heureDebut1);\par
    var endTime = new Date(startTime.getTime() + (nombreHeures * 60 * 60 * 1000)); // Dur\'e9e de l'\'e9v\'e9nement en heures\par
\par
    // Contenu de la note de l'\'e9v\'e9nement\par
    var description = `\par
    Nom: $\{nomComplet\}\par
    Adresse: $\{adresse\}\par
    T\'e9l\'e9phone: $\{numeroTelephone\}\par
    Email: $\{email\}\par
    Date: $\{formatDate(date1)\}\par
    Heure de d\'e9but: $\{formatTime(heureDebut1)\}\par
    Nombre d'heures: $\{nombreHeures\}\par
    `;\par
\par
    // Cr\'e9ation de l'\'e9v\'e9nement dans Google Calendar\par
    calendar.createEvent(`R\'e9servation de $\{nomComplet\}`, startTime, endTime, \{\par
        description: description,\par
        location: adresse\par
    \});\par
\par
    Logger.log(`\'c9v\'e9nement ajout\'e9 au calendrier pour $\{nomComplet\}`);\par
\}\par
}
